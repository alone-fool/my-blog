# Supabase（生产 / 联调必填）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 博客主 GitHub 数字 ID（与 Supabase site_config.owner_github_id 一致）
VITE_OWNER_GITHUB_ID=12345678
VITE_OWNER_GITHUB_LOGIN=alone-fool

# 站点 URL（分享链接用，生产示例）
VITE_SITE_URL=https://alone-fool.github.io/my-blog/

# 开发 Mock（仅 DEV 生效，生产构建勿设为 true）
VITE_USE_MOCK_BLOG=true
